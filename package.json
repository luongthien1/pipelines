  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "backend": "backend\\.venv\\Scripts\\python -m uvicorn main:app --app-dir backend --reload --port 8000",
    "worker": "cd backend && .venv\\Scripts\\python.exe -m worker",
    "frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\" \"npm run worker\""
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}
